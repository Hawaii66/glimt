# Copy to .env.dev.local, .env.stage.local, and .env.prod.local (gitignored).
# Each file targets one Convex *cloud* deployment (not local anonymous).

# --- Convex CLI (repo root) ---
# Deployment name from Convex dashboard → Settings → Deployment name
# Examples: dev:happy-animal-123 | prod:happy-animal-123
CONVEX_DEPLOYMENT_DEV=dev:your-dev-deployment
CONVEX_DEPLOYMENT_STAGE=prod:your-stage-deployment
CONVEX_DEPLOYMENT_PROD=prod:your-prod-deployment

# --- Expo app (used when MOBILE_ENVIRONMENT matches) ---
# From dashboard → Settings → URL
EXPO_PUBLIC_CONVEX_URL_DEV=https://your-dev-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_URL_STAGE=https://your-stage-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_URL_PROD=https://your-prod-deployment.convex.cloud

# Site URL for Convex Auth (HTTP actions domain, .convex.site)
EXPO_PUBLIC_CONVEX_SITE_URL_DEV=https://your-dev-deployment.convex.site
EXPO_PUBLIC_CONVEX_SITE_URL_STAGE=https://your-stage-deployment.convex.site
EXPO_PUBLIC_CONVEX_SITE_URL_PROD=https://your-prod-deployment.convex.site

# --- Per-environment file: only set the vars for THAT file ---
# .env.dev.local    → CONVEX_DEPLOYMENT_DEV + EXPO_PUBLIC_CONVEX_URL_DEV (+ SITE_URL_DEV)
# .env.stage.local  → CONVEX_DEPLOYMENT_STAGE + EXPO_PUBLIC_CONVEX_URL_STAGE (+ ...)
# .env.prod.local   → CONVEX_DEPLOYMENT_PROD + EXPO_PUBLIC_CONVEX_URL_PROD (+ ...)

# EAS (optional, same across envs)
EAS_PROJECT_ID=

# Mobile app environment (set in npm scripts / eas.json)
MOBILE_ENVIRONMENT=dev
