# Reference for secrets stored in Doppler (project: glimt).
# Create configs: dev, stage, prod — each holds that environment's values only.
#
# Setup:
#   doppler login
#   doppler setup          # uses doppler.yaml (default config: dev)
#   doppler secrets set CONVEX_DEPLOYMENT --config dev
#
# Run via glimt.sh (loads secrets automatically):
#   ./glimt.sh dev convex
#   ./glimt.sh dev expo

# --- Convex CLI (repo root) ---
# Deployment name from Convex dashboard → Settings → Deployment name
# Examples: dev:happy-animal-123 | prod:happy-animal-123
CONVEX_DEPLOYMENT=dev:your-dev-deployment

# --- Expo app ---
# From dashboard → Settings → URL
EXPO_PUBLIC_CONVEX_URL=https://your-dev-deployment.convex.cloud

# Site URL for Convex Auth (HTTP actions domain, .convex.site)
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-dev-deployment.convex.site

# EAS (optional)
EAS_PROJECT_ID=

# Set by glimt.sh / npm scripts (do not store in Doppler unless needed for CI)
# MOBILE_ENVIRONMENT=dev
