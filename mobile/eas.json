{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "node": "22.13.0",
      "env": {
        "MOBILE_ENVIRONMENT": "dev",
        "EAS_PROJECT_ID": "b92605ee-1590-47dd-a260-11dc4b24b3bf"
      },
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "environment": "preview",
      "node": "22.13.0",
      "env": {
        "MOBILE_ENVIRONMENT": "stage",
        "EAS_PROJECT_ID": "b92605ee-1590-47dd-a260-11dc4b24b3bf"
      }
    },
    "production": {
      "channel": "production",
      "environment": "production",
      "autoIncrement": true,
      "node": "22.13.0",
      "env": {
        "MOBILE_ENVIRONMENT": "prod",
        "EAS_PROJECT_ID": "b92605ee-1590-47dd-a260-11dc4b24b3bf"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
