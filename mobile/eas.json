{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "env": {
        "MOBILE_ENVIRONMENT": "dev"
      },
      "ios": {
        "simulator": true
      }
    },
    "staging": {
      "distribution": "internal",
      "channel": "staging",
      "environment": "preview",
      "env": {
        "MOBILE_ENVIRONMENT": "stage"
      }
    },
    "production": {
      "channel": "production",
      "environment": "production",
      "autoIncrement": true,
      "env": {
        "MOBILE_ENVIRONMENT": "prod"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
