  "dependencies": {
    "@convex-dev/auth": "^0.0.92",
    "@expo/ui": "~56.0.13",
    "@glimt/date": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@shopify/flash-list": "2.0.2",
    "convex": "^1.39.1",
    "expo": "~56.0.5",
    "expo-apple-authentication": "~56.0.4",
    "expo-application": "~56.0.3",
    "expo-background-task": "~56.0.14",
    "expo-build-properties": "~56.0.14",
    "expo-camera": "~56.0.7",
    "expo-checkbox": "~56.0.1",
    "expo-constants": "~56.0.15",
    "expo-crypto": "~56.0.3",
    "expo-dev-client": "~56.0.16",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.7",
    "expo-font": "~56.0.5",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.9",
    "expo-image-manipulator": "~56.0.16",
    "expo-image-picker": "~56.0.13",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.11",
    "expo-location": "~56.0.13",
    "expo-media-library": "~56.0.6",
    "expo-notifications": "~56.0.13",
    "expo-router": "~56.2.6",
    "expo-secure-store": "~56.0.4",
    "expo-sharing": "~56.0.13",
    "expo-sms": "~56.0.3",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-task-manager": "~56.0.14",
    "expo-updates": "~56.0.16",
    "expo-web-browser": "~56.0.5",
    "expo-widgets": "~56.0.14",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@expo/fingerprint": "^0.19.3",
    "@types/react": "~19.2.2",
    "cross-env": "^10.1.0",
    "eas-cli": "^20.3.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "pnpm run start:dev",
    "start:dev": "dotenv -e ../.env.dev.local -- cross-env MOBILE_ENVIRONMENT=dev expo start",
    "start:stage": "dotenv -e ../.env.stage.local -- cross-env MOBILE_ENVIRONMENT=stage expo start",
    "start:prod": "dotenv -e ../.env.prod.local -- cross-env MOBILE_ENVIRONMENT=prod expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "update:development": "eas update --channel development --environment development",
    "update:staging": "eas update --channel staging --environment preview",
    "update:production": "eas update --channel production --environment production",
    "eas:build": "eas build",
    "build:ios:development": "eas build --profile development --platform ios --clear-cache",
    "build:ios:staging": "eas build --profile staging --platform ios --clear-cache",
    "build:ios:production": "eas build --profile production --platform ios --clear-cache",
    "fingerprint": "pnpm exec @expo/fingerprint fingerprint:generate",
    "fingerprint:diff": "pnpm exec @expo/fingerprint fingerprint:diff"
  },
  "private": true
}
