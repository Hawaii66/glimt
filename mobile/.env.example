# Expo app — copy to .env.local (also set by `eas integrations:convex:connect` in mobile/)
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Set by `eas init` / `eas update:configure` — required for EAS Update
EAS_PROJECT_ID=
